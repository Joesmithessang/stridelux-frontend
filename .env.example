# AWS Cognito
REACT_APP_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
REACT_APP_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
REACT_APP_COGNITO_REGION=us-east-1

# API Gateway base URL
REACT_APP_API_GATEWAY_URL=https://XXXXXXXXXX.execute-api.us-east-1.amazonaws.com/prod

# S3 bucket for product images / media
REACT_APP_S3_MEDIA_URL=https://your-bucket.s3.amazonaws.com

# Stripe publishable key (safe to expose on the frontend)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXX

# true  → product/order/admin data from localStorage seed data
# false → all service calls go to real API Gateway
REACT_APP_USE_MOCK=true

# Controls auth independently of data services (defaults to REACT_APP_USE_MOCK if unset)
# true  → hardcoded mock users (customer@test.com / admin@test.com)
# false → real Amazon Cognito
REACT_APP_USE_MOCK_AUTH=false
